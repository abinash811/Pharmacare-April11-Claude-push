{
  "compilerOptions": {
    /* ── Language & Environment ─────────────────────────────────────── */
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "ES2020"],
    "jsx": "react-jsx",

    /* ── Module resolution ──────────────────────────────────────────── */
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    /* ── Path aliases (mirrors craco.config.js webpack alias) ───────── */
    "baseUrl": "src",
    "paths": {
      "@/*": ["./*"]
    },

    /* ── Gradual migration — allow .js/.jsx files alongside .ts/.tsx ── */
    "allowJs": true,
    "checkJs": false,

    /* ── Strict mode — enabled for all new .ts/.tsx files ───────────── */
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": false,

    /* ── Output ─────────────────────────────────────────────────────── */
    "noEmit": true,                  /* CRA/webpack handles transpilation */
    "isolatedModules": true,         /* Required by CRA's babel-based TS  */
    "skipLibCheck": true,            /* Skip .d.ts type checking for speed */
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "build",
    "public"
  ]
}
